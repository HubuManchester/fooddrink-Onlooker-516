<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FoodPicker"
             xmlns:helpers="clr-namespace:FoodPicker.Helpers"
             x:Class="FoodPicker.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <helpers:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <helpers:IsEmptyConverter x:Key="IsEmptyConverter" />
            <helpers:IsNotEmptyConverter x:Key="IsNotEmptyConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
