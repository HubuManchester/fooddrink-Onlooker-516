<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodPicker.Views.AlbumPage"
             Title="美食相册"
             BackgroundColor="{AppThemeBinding Light={StaticResource FoodBgLight}, Dark={StaticResource FoodBgDark}}">

    <Grid RowDefinitions="Auto,*" Padding="16" MaximumWidthRequest="450">

        <!-- 顶部拍照按钮 -->
        <Frame Grid.Row="0"
               Padding="14"
               CornerRadius="14"
               BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
               BorderColor="Transparent"
               HasShadow="True"
               Margin="0,8,0,12">

            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                    <Label Text="📸  记录你的美食"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource FoodTextPrimaryLight}, Dark={StaticResource FoodTextPrimaryDark}}" />
                    <Label Text="拍下让人心动的美食瞬间"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource FoodTextSecondaryLight}, Dark={StaticResource FoodTextSecondaryDark}}" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="📷 拍照"
                        Command="{Binding TakePhotoCommand}"
                        IsEnabled="{Binding IsTakingPhoto, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource FoodBtnTextLight}, Dark={StaticResource FoodBtnTextDark}}"
                        FontSize="15"
                        HeightRequest="44"
                        CornerRadius="22"
                        Padding="20,0"
                        VerticalOptions="Center"
                        SemanticProperties.Description="拍照按钮" />
            </Grid>
        </Frame>

        <!-- 拍照中 loading -->
        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsTakingPhoto}"
                           IsVisible="{Binding IsTakingPhoto}"
                           Color="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}"
                           HeightRequest="40"
                           VerticalOptions="End"
                           HorizontalOptions="Center"
                           Margin="0,0,0,-30" />

        <!-- 空状态 -->
        <VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12"
                             IsVisible="{Binding IsEmpty}">
            <Label Text="🖼️"
                   FontSize="64"
                   HorizontalTextAlignment="Center" />
            <Label Text="还没有美食照片"
                   FontSize="18"
                   TextColor="{AppThemeBinding Light={StaticResource FoodTextSecondaryLight}, Dark={StaticResource FoodTextSecondaryDark}}"
                   HorizontalTextAlignment="Center" />
            <Label Text="点击上方按钮拍一张吧~"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource FoodTextMutedLight}, Dark={StaticResource FoodTextMutedDark}}"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- 照片网格 -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding Photos}"
                         IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="2"
                                 HorizontalItemSpacing="8"
                                 VerticalItemSpacing="8" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="删除"
                                           BackgroundColor="{AppThemeBinding Light={StaticResource FoodDangerLight}, Dark={StaticResource FoodDangerDark}}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeletePhotoCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Padding="0"
                               CornerRadius="12"
                               BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
                               BorderColor="Transparent"
                               HasShadow="True"
                               HeightRequest="160">
                            <Grid>
                                <Image Source="{Binding .}"
                                       Aspect="AspectFill" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewPhotoCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
