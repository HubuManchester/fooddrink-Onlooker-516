<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodPicker.Views.RandomPage"
             Title="Discover"
             BackgroundColor="{AppThemeBinding Light={StaticResource FoodBgLight}, Dark={StaticResource FoodBgDark}}">

    <Grid RowDefinitions="Auto,Auto,Auto,*"
          Padding="24"
          MaximumWidthRequest="400">

        <!-- 顶部标题 -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Padding="0,20,0,0">
            <Label Text="What to eat today?"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}"
                   AutomationProperties.IsInAccessibleTree="True" />

            <Label Text="Shake your phone or tap below!"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource FoodTextSecondaryLight}, Dark={StaticResource FoodTextSecondaryDark}}"
                   AutomationProperties.IsInAccessibleTree="True" />
        </VerticalStackLayout>

        <!-- 输入栏：我想吃... -->
        <Frame Grid.Row="1"
               Padding="4"
               CornerRadius="24"
               BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
               BorderColor="{AppThemeBinding Light={StaticResource FoodDividerLight}, Dark={StaticResource FoodDividerDark}}"
               HasShadow="False"
               Margin="0,10,0,0">

            <Grid ColumnDefinitions="*,Auto">
                <Entry Grid.Column="0"
                       Text="{Binding CravingText}"
                       Placeholder="💡 Search for a dish..."
                       PlaceholderColor="{AppThemeBinding Light=#BBBBBB, Dark=#5A4A3A}"
                       TextColor="{AppThemeBinding Light={StaticResource FoodTextPrimaryLight}, Dark={StaticResource FoodTextPrimaryDark}}"
                       BackgroundColor="Transparent"
                       FontSize="15"
                       ClearButtonVisibility="WhileEditing"
                       ReturnType="Done"
                       AutomationProperties.IsInAccessibleTree="True" />

                <Button Grid.Column="1"
                        Text="🔍 找找看"
                        Command="{Binding SearchFoodCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource FoodBtnTextLight}, Dark={StaticResource FoodBtnTextDark}}"
                        FontSize="14"
                        HeightRequest="40"
                        CornerRadius="20"
                        Padding="16,0"
                        VerticalOptions="Center"
                        SemanticProperties.Description="搜索输入的美食名称" />
            </Grid>
        </Frame>

        <!-- 食物展示卡片 -->
        <Frame x:Name="FoodCard"
               Grid.Row="2"
               VerticalOptions="Center"
               Padding="24"
               CornerRadius="16"
               BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
               BorderColor="Transparent"
               HasShadow="True"
               AutomationProperties.IsInAccessibleTree="True">

            <VerticalStackLayout Spacing="12">
                <!-- Emoji -->
                <Label x:Name="EmojiLabel"
                       Text="{Binding CurrentFood.Emoji}"
                       FontSize="80"
                       HorizontalTextAlignment="Center"
                       AutomationProperties.IsInAccessibleTree="True" />

                <!-- 食物名 -->
                <Label Text="{Binding CurrentFood.Name}"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource FoodTextPrimaryLight}, Dark={StaticResource FoodTextPrimaryDark}}"
                       AutomationProperties.IsInAccessibleTree="True" />

                <!-- 类别标签 -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Frame Padding="10,4"
                           CornerRadius="12"
                           BackgroundColor="{AppThemeBinding Light={StaticResource FoodAccentBgLight}, Dark={StaticResource FoodAccentBgDark}}"
                           BorderColor="Transparent">
                        <Label Text="{Binding CurrentFood.Category}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}" />
                    </Frame>
                </HorizontalStackLayout>

                <!-- 介绍文字 -->
                <Label Text="{Binding CurrentFood.Description}"
                       FontSize="15"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource FoodTextPrimaryLight}, Dark={StaticResource FoodTextPrimaryDark}}"
                       LineHeight="1.5" />

                <!-- 分割线 -->
                <BoxView HeightRequest="1"
                         Color="{AppThemeBinding Light={StaticResource FoodDividerLight}, Dark={StaticResource FoodDividerDark}}"
                         Margin="8,4" />

                <!-- 推荐搭配 -->
                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="💡"
                           FontSize="14"
                           VerticalTextAlignment="Center" />
                    <Label Text="{Binding CurrentFood.Pairing}"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#C06A2A, Dark=#D48A4A}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <!-- 底部按钮区 -->
        <HorizontalStackLayout Grid.Row="3"
                                Spacing="10"
                                HorizontalOptions="Center"
                                VerticalOptions="End"
                                Padding="0,0,0,20">

            <Button Text="🔄 Pick"
                    Command="{Binding RandomPickCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource FoodBtnTextLight}, Dark={StaticResource FoodBtnTextDark}}"
                    FontSize="13"
                    HeightRequest="42"
                    CornerRadius="21"
                    Padding="16,0"
                    SemanticProperties.Description="Pick another dish" />

            <Button Text="{Binding FavBtnText}"
                    Command="{Binding AddFavoriteCommand}"
                    BackgroundColor="{Binding IsFavorited, Converter={StaticResource FavBtnColorConverter}}"
                    TextColor="White"
                    FontSize="13"
                    HeightRequest="42"
                    CornerRadius="21"
                    Padding="16,0"
                    SemanticProperties.Description="Save this dish" />

            <Button Text="📤 Share"
                    Command="{Binding ShareCommand}"
                    BackgroundColor="{AppThemeBinding Light=#4A90D9, Dark=#336699}"
                    TextColor="White"
                    FontSize="13"
                    HeightRequest="42"
                    CornerRadius="21"
                    Padding="16,0"
                    SemanticProperties.Description="Share this dish" />

        </HorizontalStackLayout>
    </Grid>
</ContentPage>
