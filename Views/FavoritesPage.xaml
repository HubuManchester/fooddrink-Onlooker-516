<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodPicker.Views.FavoritesPage"
             Title="我的收藏"
             BackgroundColor="{AppThemeBinding Light={StaticResource FoodBgLight}, Dark={StaticResource FoodBgDark}}">

    <Grid RowDefinitions="*,Auto" Padding="16" MaximumWidthRequest="450">
        <Grid.GestureRecognizers>
            <SwipeGestureRecognizer Direction="Left" Swiped="OnSwipedLeft" />
            <SwipeGestureRecognizer Direction="Right" Swiped="OnSwipedRight" />
        </Grid.GestureRecognizers>

        <!-- 空状态提示 -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12"
                             IsVisible="{Binding IsEmpty}">
            <Label Text="📭"
                   FontSize="64"
                   HorizontalTextAlignment="Center" />
            <Label Text="还没有收藏任何美食"
                   FontSize="18"
                   TextColor="{AppThemeBinding Light={StaticResource FoodTextSecondaryLight}, Dark={StaticResource FoodTextSecondaryDark}}"
                   HorizontalTextAlignment="Center" />
            <Label Text="去「随机推荐」页找找灵感吧~"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource FoodTextMutedLight}, Dark={StaticResource FoodTextMutedDark}}"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- 收藏列表 -->
        <CollectionView Grid.Row="0"
                         ItemsSource="{Binding FavoriteItems}"
                         IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="删除"
                                           BackgroundColor="{AppThemeBinding Light={StaticResource FoodDangerLight}, Dark={StaticResource FoodDangerDark}}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Margin="0,0,0,10"
                               Padding="16"
                               CornerRadius="14"
                               BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
                               BorderColor="Transparent"
                               HasShadow="True">

                            <!-- 点击整张卡片编辑笔记 -->
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditNoteCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="60,*" MinimumHeightRequest="70">
                                <Label Grid.Column="0"
                                       Text="{Binding Food.Emoji}"
                                       FontSize="36"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />

                                <VerticalStackLayout Grid.Column="1"
                                                      Padding="8,0,0,0"
                                                      Spacing="4"
                                                      VerticalOptions="Center">
                                    <Label Text="{Binding Food.Name}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource FoodTextPrimaryLight}, Dark={StaticResource FoodTextPrimaryDark}}" />
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="{Binding Food.Category}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}" />
                                    </HorizontalStackLayout>

                                    <!-- 有笔记时显示笔记预览 -->
                                    <Label Text="{Binding Note, StringFormat='📝 {0}'}"
                                           FontSize="12"
                                           TextColor="#E85D04"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"
                                           IsVisible="{Binding Note, Converter={StaticResource IsNotEmptyConverter}}" />

                                    <!-- 没笔记时显示提示 -->
                                    <Label Text="💬 点击添加评价..."
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#BBBBBB, Dark=#6A5A4A}"
                                           IsVisible="{Binding Note, Converter={StaticResource IsEmptyConverter}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 底部清空按钮 -->
        <Button Grid.Row="1"
                Text="🗑  清空所有收藏"
                Command="{Binding ClearAllCommand}"
                BackgroundColor="{AppThemeBinding Light={StaticResource FoodWarnLight}, Dark={StaticResource FoodWarnDark}}"
                TextColor="{AppThemeBinding Light={StaticResource FoodBtnTextLight}, Dark={StaticResource FoodBtnTextDark}}"
                FontSize="14"
                HeightRequest="44"
                CornerRadius="22"
                Margin="0,8,0,16"
                IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}" />
    </Grid>
</ContentPage>
