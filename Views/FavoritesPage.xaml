<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodPicker.Views.FavoritesPage"
             Title="Favourites"
             BackgroundColor="{AppThemeBinding Light={StaticResource FoodBgLight}, Dark={StaticResource FoodBgDark}}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" MaximumWidthRequest="450">

        <!-- ===== 统计卡片 ===== -->
        <Frame Grid.Row="0" Padding="14" CornerRadius="14" HasShadow="True" Margin="0,4,0,8"
               BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
               BorderColor="Transparent"
               IsVisible="{Binding HasStats}">
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="📊" FontSize="18" VerticalTextAlignment="Center" />
                <Label Text="{Binding StatsText}" FontSize="15" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource FoodTextPrimaryLight}, Dark={StaticResource FoodTextPrimaryDark}}"
                       VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
        </Frame>

        <!-- ===== 随手选一个 ===== -->
        <Button Grid.Row="1" Text="🎲  Pick One for Me"
                Command="{Binding RandomPickCommand}"
                BackgroundColor="{AppThemeBinding Light=#FF8C42, Dark=#CC6633}"
                TextColor="White" FontSize="14"
                HeightRequest="42" CornerRadius="21"
                Margin="0,0,0,10"
                IsVisible="{Binding HasStats}" />

        <!-- ===== 空状态 ===== -->
        <VerticalStackLayout Grid.Row="2" VerticalOptions="Center"
                             HorizontalOptions="Center" Spacing="14"
                             IsVisible="{Binding IsEmpty}">
            <Label Text="📭" FontSize="56" HorizontalTextAlignment="Center" />
            <Label Text="No favourites yet" FontSize="18"
                   TextColor="{AppThemeBinding Light={StaticResource FoodTextSecondaryLight}, Dark={StaticResource FoodTextSecondaryDark}}"
                   HorizontalTextAlignment="Center" />
            <Label Text="去「Discover」页找找灵感吧~" FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource FoodTextMutedLight}, Dark={StaticResource FoodTextMutedDark}}"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- ===== 收藏列表 ===== -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding FavoriteItems}"
                         IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="{AppThemeBinding Light={StaticResource FoodDangerLight}, Dark={StaticResource FoodDangerDark}}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Margin="0,0,0,10" Padding="14" CornerRadius="14" HasShadow="True"
                               BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
                               BorderColor="Transparent">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditNoteCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="56,*" MinimumHeightRequest="64">
                                <!-- 大 emoji -->
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 28"
                                        Stroke="Transparent" HeightRequest="52" WidthRequest="52"
                                        BackgroundColor="{AppThemeBinding Light=#FFF2E6, Dark=#2A2018}"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding Food.Emoji}" FontSize="28"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Padding="10,0,0,0"
                                                      Spacing="3" VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Food.Name}" FontSize="17" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#333333, Dark=#E8D5C4}" />
                                        <!-- 笔记角标 -->
                                        <Frame Padding="6,2" CornerRadius="8" HasShadow="False"
                                               BackgroundColor="#E85D04" BorderColor="Transparent"
                                               IsVisible="{Binding Note, Converter={StaticResource IsNotEmptyConverter}}"
                                               VerticalOptions="Center">
                                            <Label Text="✏️" FontSize="10" TextColor="White" />
                                        </Frame>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Food.Category}" FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}" />
                                    <!-- 笔记预览 -->
                                    <Label Text="{Binding Note}" FontSize="12"
                                           TextColor="{AppThemeBinding Light=#999999, Dark=#6A5A4A}"
                                           LineBreakMode="TailTruncation" MaxLines="1"
                                           IsVisible="{Binding Note, Converter={StaticResource IsNotEmptyConverter}}" />
                                    <Label Text="💬 💬 Tap to add a note..." FontSize="12"
                                           TextColor="{AppThemeBinding Light=#BBBBBB, Dark=#5A4A3A}"
                                           IsVisible="{Binding Note, Converter={StaticResource IsEmptyConverter}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ===== Clear按钮 ===== -->
        <Button Grid.Row="3" Text="🗑  Clear All"
                Command="{Binding ClearAllCommand}"
                BackgroundColor="{AppThemeBinding Light={StaticResource FoodWarnLight}, Dark={StaticResource FoodWarnDark}}"
                TextColor="White" FontSize="14"
                HeightRequest="42" CornerRadius="21"
                Margin="0,6,0,16"
                IsVisible="{Binding HasStats}" />
    </Grid>
</ContentPage>
