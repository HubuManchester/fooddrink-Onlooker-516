<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodPicker.Views.CompassPage"
             Title="美食指南"
             BackgroundColor="{AppThemeBinding Light={StaticResource FoodBgLight}, Dark={StaticResource FoodBgDark}}">

    <Grid RowDefinitions="380,*" Padding="16" MaximumWidthRequest="420">

        <Grid Grid.Row="0"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              WidthRequest="320" HeightRequest="320">

            <Ellipse WidthRequest="320" HeightRequest="320"
                     Fill="{AppThemeBinding Light=#FFF5ED, Dark=#1F1810}"
                     Stroke="{AppThemeBinding Light=#E07030, Dark=#CC6633}"
                     StrokeThickness="4" />
            <Ellipse WidthRequest="305" HeightRequest="305"
                     Fill="Transparent"
                     Stroke="{AppThemeBinding Light=#F0D0B0, Dark=#3A2A18}"
                     StrokeThickness="1" />
            <Ellipse WidthRequest="240" HeightRequest="240"
                     Fill="Transparent"
                     Stroke="{AppThemeBinding Light=#F0D0B0, Dark=#3A2A18}"
                     StrokeThickness="0.5" />

            <Grid x:Name="CompassRose"
                  WidthRequest="320" HeightRequest="320"
                  AnchorX="160" AnchorY="160">

                <Label Text="N" FontSize="24" FontAttributes="Bold"
                       TextColor="#E85D04"
                       HorizontalOptions="Center" VerticalOptions="Start"
                       Margin="0,14,0,0" />
                <Label Text="S" FontSize="19"
                       TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}"
                       HorizontalOptions="Center" VerticalOptions="End"
                       Margin="0,0,0,14" />
                <Label Text="E" FontSize="18"
                       TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}"
                       HorizontalOptions="End" VerticalOptions="Center"
                       Margin="0,0,16,0" />
                <Label Text="W" FontSize="18"
                       TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}"
                       HorizontalOptions="Start" VerticalOptions="Center"
                       Margin="16,0,0,0" />
                <Label Text="NE" FontSize="11"
                       TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                       HorizontalOptions="End" VerticalOptions="Start"
                       Margin="0,40,50,0" />
                <Label Text="SE" FontSize="11"
                       TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                       HorizontalOptions="End" VerticalOptions="End"
                       Margin="0,0,50,40" />
                <Label Text="SW" FontSize="11"
                       TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                       HorizontalOptions="Start" VerticalOptions="End"
                       Margin="50,0,0,40" />
                <Label Text="NW" FontSize="11"
                       TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                       HorizontalOptions="Start" VerticalOptions="Start"
                       Margin="50,40,0,0" />

                <Polygon Points="160,8 152,38 168,38"
                         Fill="#E85D04"
                         HorizontalOptions="Center" VerticalOptions="Start" />
                <Polygon Points="160,312 152,282 168,282"
                         Fill="{AppThemeBinding Light=#999999, Dark=#555555}"
                         HorizontalOptions="Center" VerticalOptions="End" />
            </Grid>

            <Frame WidthRequest="70" HeightRequest="70"
                   CornerRadius="35"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2218}"
                   BorderColor="{AppThemeBinding Light=#E07030, Dark=#CC6633}"
                   Padding="0"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   HasShadow="True">
                <Ellipse WidthRequest="58" HeightRequest="58"
                         Fill="Transparent"
                         Stroke="{AppThemeBinding Light=#F0D0B0, Dark=#4A3020}"
                         StrokeThickness="1"
                         HorizontalOptions="Center" VerticalOptions="Center" />
                <Label Text="{Binding DirectionEmoji}"
                       FontSize="24"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Frame>

            <Frame WidthRequest="100" HeightRequest="34"
                   CornerRadius="17"
                   BackgroundColor="{AppThemeBinding Light=#E85D04, Dark=#FF8C42}"
                   BorderColor="Transparent"
                   Padding="0"
                   HorizontalOptions="Center" VerticalOptions="End"
                   Margin="0,0,0,-8"
                   HasShadow="True">
                <Label HorizontalOptions="Center" VerticalOptions="Center"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="White"
                       Text="{Binding HeadingDegrees}" />
            </Frame>
        </Grid>

        <VerticalStackLayout Grid.Row="1" Spacing="10" Padding="0,8,0,16">
            <Label Text="{Binding DirectionText}"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#333333, Dark=#E8D5C4}" />

            <Frame Padding="16" CornerRadius="14"
                   BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
                   BorderColor="Transparent" HasShadow="True"
                   IsVisible="{Binding HasReading}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🍽️  当前方位推荐" FontSize="14" FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}" />
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="{Binding RecommendedFood.Emoji}"
                               FontSize="44" VerticalTextAlignment="Center" />
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding RecommendedFood.Name}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#E8D5C4}" />
                            <Label Text="{Binding RecommendedFood.Category}" FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <Label Text="{Binding RecommendedFood.Description}" FontSize="13"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#666666, Dark=#8A7A6A}" LineHeight="1.4" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="转动手机，探索不同方位的美食"
                   FontSize="13"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#BBBBBB, Dark=#5A4A3A}" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>