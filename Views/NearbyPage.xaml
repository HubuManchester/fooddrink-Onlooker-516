<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodPicker.Views.NearbyPage"
             Title="附近美食"
             BackgroundColor="{AppThemeBinding Light=#FFF5ED, Dark=#1A1410}">

    <Grid RowDefinitions="Auto,*" Padding="16" MaximumWidthRequest="450">

        <!-- 顶部定位卡片 -->
        <Frame Grid.Row="0"
               Padding="16"
               CornerRadius="14"
               BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
               BorderColor="Transparent"
               HasShadow="True"
               Margin="0,12,0,0">

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <!-- 状态文字 -->
                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                    <Label Text="{Binding StatusEmoji}" FontSize="22" VerticalTextAlignment="Center" />
                    <Label Text="{Binding LocationText}"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource FoodTextPrimaryLight}, Dark={StaticResource FoodTextPrimaryDark}}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- 刷新按钮 -->
                <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                        Text="🔄"
                        Command="{Binding RefreshCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource FoodBtnTextLight}, Dark={StaticResource FoodBtnTextDark}}"
                        FontSize="18"
                        WidthRequest="44" HeightRequest="44"
                        CornerRadius="22"
                        Padding="0"
                        VerticalOptions="Center"
                        SemanticProperties.Description="刷新定位" />

                <!-- Loading -->
                <ActivityIndicator Grid.Row="1" Grid.Column="0"
                                   IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}"
                                   HeightRequest="30"
                                   HorizontalOptions="Start" />
            </Grid>
        </Frame>

        <!-- 附近美食列表 -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding NearbyFoods}"
                         Margin="0,12,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,12"
                           Padding="0"
                           CornerRadius="14"
                           BackgroundColor="{AppThemeBinding Light={StaticResource FoodCardLight}, Dark={StaticResource FoodCardDark}}"
                           BorderColor="Transparent"
                           HasShadow="True">

                        <Grid ColumnDefinitions="90,*" MinimumHeightRequest="110">

                            <!-- 左侧大 emoji -->
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle 14,0,0,14"
                                    Stroke="Transparent"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource FoodEmojiBgLight}, Dark={StaticResource FoodEmojiBgDark}}"
                                    WidthRequest="90">
                                <Label Text="{Binding Emoji}"
                                       FontSize="38"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>

                            <!-- 右侧信息区 -->
                            <VerticalStackLayout Grid.Column="1"
                                                  Padding="14,12"
                                                  Spacing="4"
                                                  VerticalOptions="Center">
                                <!-- 店名 -->
                                <Label Text="{Binding Name}"
                                       FontSize="17" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#222222, Dark=#E8D5C4}"
                                       LineBreakMode="TailTruncation" />

                                <!-- 评分 + 价格 + 距离 -->
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding Rating, StringFormat='⭐ {0}'}"
                                           FontSize="13" TextColor="#F5A623" />
                                    <Label Text="{Binding Price}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource FoodTextSecondaryLight}, Dark={StaticResource FoodTextSecondaryDark}}" />
                                    <Label Text="{Binding Distance}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource FoodTextSecondaryLight}, Dark={StaticResource FoodTextSecondaryDark}}" />
                                </HorizontalStackLayout>

                                <!-- 分类标签 -->
                                <Label Text="{Binding Category}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource FoodAccentLight}, Dark={StaticResource FoodAccentDark}}" />

                                <!-- 简介 -->
                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#888888, Dark=#8A7A6A}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
