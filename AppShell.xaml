<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodPicker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FoodPicker.Views"
    Title="FoodPicker">

    <TabBar>
        <ShellContent
            Title="Discover"
            ContentTemplate="{DataTemplate views:RandomPage}"
            Route="RandomPage" />

        <ShellContent
            Title="Compass"
            ContentTemplate="{DataTemplate views:CompassPage}"
            Route="CompassPage" />

        <ShellContent
            Title="Album"
            ContentTemplate="{DataTemplate views:AlbumPage}"
            Route="AlbumPage" />

        <ShellContent
            Title="Favourites"
            ContentTemplate="{DataTemplate views:FavoritesPage}"
            Route="FavoritesPage" />
    </TabBar>

</Shell>
