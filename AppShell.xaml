<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodPicker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FoodPicker.Views"
    Title="今天吃什么">

    <TabBar>
        <ShellContent
            Title="随机推荐"
            ContentTemplate="{DataTemplate views:RandomPage}"
            Route="RandomPage" />

        <ShellContent
            Title="美食指南"
            ContentTemplate="{DataTemplate views:CompassPage}"
            Route="CompassPage" />

        <ShellContent
            Title="美食相册"
            ContentTemplate="{DataTemplate views:AlbumPage}"
            Route="AlbumPage" />

        <ShellContent
            Title="我的收藏"
            ContentTemplate="{DataTemplate views:FavoritesPage}"
            Route="FavoritesPage" />
    </TabBar>

</Shell>
